# 复制为 .env 后按需修改

# 运行环境
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# 数据库
DATABASE_URL=mysql+pymysql://root:root@localhost:3306/smart_sop
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# CORS（逗号分隔多个）
CORS_ORIGINS=http://localhost:5173

# 上传
UPLOAD_MAX_SIZE_MB=50

# PDF 字体目录
PDF_FONT_DIR=app/assets/fonts
